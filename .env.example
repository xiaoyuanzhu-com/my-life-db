# User Configuration
USERNAME=default

# Host Directory Mounts (relative to user deployment directory)
# These are mounted into the container at specific paths
HOST_USER_DATA_DIR=./data
HOST_APP_DATA_DIR=./.my-life-db
HOST_CLAUDE_DIR=./.claude

# Authentication Mode (none, password, oauth)
# For cloud deployment, use oauth
MLD_AUTH_MODE=oauth

# OAuth Configuration (when MLD_AUTH_MODE=oauth)
MLD_OAUTH_CLIENT_ID=
MLD_OAUTH_CLIENT_SECRET=
MLD_OAUTH_ISSUER_URL=
MLD_OAUTH_REDIRECT_URI=
# For user instances (NOT user-default), set expected username for security
# user-default should NOT have this set (it handles OAuth for all users)
MLD_EXPECTED_USERNAME=${USERNAME}

# Agent LLM Gateway (optional — when set, agents use this instead of their own credentials)
# All agent types (Claude Code, Codex) are routed through this gateway.
# AGENT_BASE_URL=https://litellm.example.com
# AGENT_API_KEY=sk-your-gateway-key
# AGENT_CUSTOMER_ID=${USERNAME}
# AGENT_MODELS=[{"value":"default","name":"Default","description":"Server default"}]

# Qdrant Configuration
QDRANT_URL=http://qdrant:6334

# Staging Configuration (for run.js github command)
# Get a URL from https://smee.io
SMEE_URL=
